<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="14dp"
    android:layout_marginBottom="8dp" android:background="#EAF3DE">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="6dp">
        <TextView android:id="@+id/tv_date" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:text="2025-04-17" android:textSize="13sp"
            android:textStyle="bold" android:textColor="#27500A"/>
        <TextView android:id="@+id/tv_co2" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="0.42 kg CO₂"
            android:textSize="13sp" android:textStyle="bold" android:textColor="#791F1F"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:id="@+id/tv_walk" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:text="3.2 km walked" android:textSize="11sp" android:textColor="#3B6D11"/>
        <TextView android:id="@+id/tv_vehicle" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:text="8.1 km vehicle" android:textSize="11sp" android:textColor="#A32D2D"/>
        <TextView android:id="@+id/tv_saved" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:text="0.38 kg saved" android:textSize="11sp" android:textColor="#27500A"
            android:gravity="end"/>
    </LinearLayout>

</LinearLayout>
