<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F1EFE8">

    <!-- Top bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#27500A" android:padding="20dp" android:orientation="horizontal"
        android:gravity="center_vertical">
        <Button android:id="@+id/btn_back" android:layout_width="wrap_content"
            android:layout_height="36dp" android:text="Back" android:textSize="12sp"
            android:backgroundTint="#3B6D11" android:textColor="#EAF3DE" android:layout_marginEnd="12dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Live tracking"
            android:textSize="16sp" android:textStyle="bold" android:textColor="#EAF3DE"/>
        <TextView android:id="@+id/tv_co2_today" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="0.00 kg CO₂ today"
            android:textSize="11sp" android:textColor="#97C459"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <!-- Mode card -->
            <androidx.cardview.widget.CardView android:id="@+id/card_mode"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" app:cardCornerRadius="16dp"
                app:cardElevation="0dp" app:cardBackgroundColor="#27500A">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="24dp" android:gravity="center">
                    <TextView android:id="@+id/tv_current_mode" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Stationary"
                        android:textSize="32sp" android:textStyle="bold" android:textColor="#EAF3DE"/>
                    <TextView android:id="@+id/tv_co2_rate" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="No movement"
                        android:textSize="14sp" android:textColor="#97C459" android:layout_marginTop="4dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center"
                        android:layout_marginTop="16dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="24dp">
                            <TextView android:id="@+id/tv_speed" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0.0 km/h"
                                android:textSize="20sp" android:textStyle="bold" android:textColor="#EAF3DE"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Speed" android:textSize="11sp" android:textColor="#5DCAA5"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="vertical" android:gravity="center" android:layout_marginHorizontal="24dp">
                            <TextView android:id="@+id/tv_co2_trip" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0.0 g"
                                android:textSize="20sp" android:textStyle="bold" android:textColor="#EAF3DE"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="CO₂ this trip" android:textSize="11sp" android:textColor="#5DCAA5"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Distance breakdown -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Today's breakdown" android:textSize="12sp"
                        android:textColor="#888780" android:layout_marginBottom="10dp"/>
                    <TextView android:id="@+id/tv_walk_km" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0.00 km walking"
                        android:textSize="14sp" android:textColor="#27500A" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tv_vehicle_km" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0.00 km vehicle"
                        android:textSize="14sp" android:textColor="#791F1F" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tv_saved" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0.00 kg CO₂ saved by walking"
                        android:textSize="13sp" android:textColor="#3B6D11" android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button android:id="@+id/btn_stop_tracking" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="Stop tracking"
                android:textSize="14sp" android:backgroundTint="#791F1F" android:textColor="#FCEBEB"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
