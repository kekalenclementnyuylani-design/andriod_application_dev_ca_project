<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="10dp" app:cardCornerRadius="10dp"
    app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="6dp">
            <TextView android:id="@+id/tv_day_date" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="2024-01-01" android:textSize="14sp" android:textStyle="bold"
                android:textColor="#2C2C2A"/>
            <TextView android:id="@+id/tv_day_co2" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0.00 kg CO2"
                android:textSize="14sp" android:textStyle="bold" android:textColor="#27500A"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/tv_day_walking" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Walk: 0.0 km" android:textSize="12sp" android:textColor="#3B6D11"/>
            <TextView android:id="@+id/tv_day_vehicle" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Vehicle: 0.0 km" android:textSize="12sp" android:textColor="#A32D2D"/>
            <TextView android:id="@+id/tv_day_saved" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Saved: 0g" android:textSize="12sp" android:textColor="#085041"
                android:gravity="end"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
