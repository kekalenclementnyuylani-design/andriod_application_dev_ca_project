<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F1EFE8">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#27500A" android:padding="20dp" android:orientation="horizontal"
        android:gravity="center_vertical">
        <Button android:id="@+id/btn_back" android:layout_width="wrap_content"
            android:layout_height="36dp" android:text="Back"
            android:textSize="13sp" android:backgroundTint="#173404" android:textColor="#97C459"
            android:layout_marginEnd="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Weekly history" android:textSize="18sp" android:textStyle="bold"
            android:textColor="#EAF3DE"/>
    </LinearLayout>

    <!-- Weekly summary card -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp" android:weightSum="2">
        <androidx.cardview.widget.CardView android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:layout_marginEnd="8dp" app:cardCornerRadius="10dp"
            app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Total CO₂" android:textSize="11sp" android:textColor="#888780"/>
                <TextView android:id="@+id/tv_total_week_co2" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0.00 kg"
                    android:textSize="18sp" android:textStyle="bold" android:textColor="#791F1F"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            app:cardCornerRadius="10dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CO₂ saved" android:textSize="11sp" android:textColor="#888780"/>
                <TextView android:id="@+id/tv_total_saved" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0.00 kg saved"
                    android:textSize="16sp" android:textStyle="bold" android:textColor="#27500A"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingHorizontal="16dp"
        android:paddingBottom="12dp" android:weightSum="2">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Cleanest day"
            android:textSize="12sp" android:textColor="#888780"/>
        <TextView android:id="@+id/tv_cleanest_day" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:text="—" android:textSize="12sp" android:textColor="#27500A"
            android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingHorizontal="16dp"
        android:paddingBottom="16dp" android:weightSum="2">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Worst day"
            android:textSize="12sp" android:textColor="#888780"/>
        <TextView android:id="@+id/tv_worst_day" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:text="—" android:textSize="12sp" android:textColor="#791F1F"
            android:textStyle="bold" android:gravity="end"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_days"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="16dp" android:clipToPadding="false"/>

</LinearLayout>
